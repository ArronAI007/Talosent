TALOSENT_APP_NAME=Talosent
TALOSENT_ENV=development
TALOSENT_LOG_LEVEL=INFO
TALOSENT_PROVIDER=local
TALOSENT_MODEL=stub
# Set this locally; do not commit a real secret.
TALOSENT_OPENAI_API_KEY=
TALOSENT_OPENAI_BASE_URL=https://api.openai.com/v1
TALOSENT_MEMORY_BACKEND=in_memory
TALOSENT_STORAGE_BACKEND=filesystem
TALOSENT_RECENT_TURNS=4
TALOSENT_MEMORY_FACT_LIMIT=8
TALOSENT_SUMMARY_TURN_PREVIEW_LIMIT=8
TALOSENT_SUMMARY_CHAR_LIMIT=2000
TALOSENT_API_HOST=127.0.0.1
TALOSENT_API_PORT=8000
TALOSENT_WEB_ENABLED=false
TALOSENT_TUI_ENABLED=false
